# ============================================================
# HL7 & EHR → FHIR Converter — Environment Variables
# Innova Solutions  |  CS06
# ============================================================
# 1. Copy this file:   cp .env.example .env
# 2. Fill in your API keys below
# 3. Run:              docker compose up --build
# ============================================================

# ── AI Provider Keys ─────────────────────────────────────────
# Claude Sonnet 4.6 (Anthropic) — https://console.anthropic.com
# Create an account → API Keys → Create Key
ANTHROPIC_API_KEY=sk-ant-api03-YOUR_KEY_HERE

# Groq (free 100k tokens/day) — https://console.groq.com
# Create an account → API Keys → Create API Key
GROQ_API_KEY=gsk_YOUR_KEY_HERE

# ── App Settings ─────────────────────────────────────────────
# Port to expose on your machine (default: 8000)
APP_PORT=8000

# Uvicorn worker processes (default: 2)
WORKERS=2

# Log level: debug | info | warning | error | critical
LOG_LEVEL=info

# CORS# Allowed CORS origins (comma-separated, typically http://localhost:3000 in dev)
ALLOWED_ORIGINS=*

# ---------------------------------------------------------------------------
# Database Settings
# ---------------------------------------------------------------------------
# Format: postgresql://<user>:<password>@<host>:<port>/<db_name>
DATABASE_URL=postgresql://postgres:password@localhost:5432/innova_fhir
