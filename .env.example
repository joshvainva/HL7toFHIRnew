# HL7 → FHIR Converter — Environment Variables
# Copy this file to .env and edit as needed.

# Port to expose the web application on the host
APP_PORT=8000

# Comma-separated list of allowed CORS origins (use * for dev only)
ALLOWED_ORIGINS=*

# Uvicorn log level: debug | info | warning | error | critical
LOG_LEVEL=info
